# Copy this file to backend/.env and fill in real values from the Supabase dashboard:
#   Supabase project -> Settings -> API / Database
# Do NOT commit the real .env file.

APP_VERSION=0.1.0
LOG_LEVEL=INFO
MC_SEED=42
ENVIRONMENT=development

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Rate limit for /risk/* (format: "<count>/<second|minute|hour>")
RATE_LIMIT_RISK=60/minute

SUPABASE_URL=<replace-me>
SUPABASE_ANON_KEY=<replace-me>
SUPABASE_SERVICE_ROLE_KEY=<replace-me>
SUPABASE_JWT_SECRET=<replace-me>

# SQLAlchemy async URL, e.g. postgresql+asyncpg://postgres:<pwd>@<host>:5432/postgres
DATABASE_URL=<replace-me>

# JSON-encoded list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]
